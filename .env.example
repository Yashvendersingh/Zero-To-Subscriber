# ==============================================================================
# ResumeAI Configuration Template (.env)
# Copy this file to '.env' inside 'backend/' and configure the values.
# ==============================================================================

# FastAPI Backend Configuration
SECRET_KEY=super-secret-jwt-signing-key-use-long-random-string
REFRESH_SECRET_KEY=super-secret-refresh-jwt-signing-key-use-long-random-string
FRONTEND_URL=http://localhost:5173

# Database Connections
# Fallback is a local SQLite file (sqlite+aiosqlite:///./sql_app.db) if left blank
# For Production (Neon PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://[user]:[password]@[host].neon.tech/[dbname]?sslmode=require
DATABASE_URL=sqlite+aiosqlite:///./sql_app.db

# Stripe Payment Integrations (Optional, falls back to Mock simulator if empty)
STRIPE_SECRET_KEY=sk_test_51...
STRIPE_PUBLISHABLE_KEY=pk_test_51...
STRIPE_PRICE_PRO=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google Gemini API Key (Optional, falls back to Mock evaluations if empty)
GEMINI_API_KEY=AIzaSy...

# ==============================================================================
# Frontend Environment variables (.env)
# Create a '.env' inside 'frontend/' containing:
# VITE_API_URL=http://localhost:8000
# ==============================================================================
